<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:id="@+id/layout_splash_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0.0"> <!-- Will animate alpha to 1.0 in Java -->

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/aruskas_logo_v2"
            android:contentDescription="ArusKas Logo" />

        <TextView
            style="@style/TextAppearance.ArusKas.Display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ArusKas"
            android:textSize="32sp"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />

        <TextView
            style="@style/TextAppearance.ArusKas.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Asisten Finansial Terpercaya Anda"
            android:textColor="@color/colorTextSecondary"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>
