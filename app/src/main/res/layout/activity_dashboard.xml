<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".activity.DashboardActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Title Header with Brand Logo, App Name & Logout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="@dimen/space_l"
                android:layout_marginTop="@dimen/space_xl"
                android:layout_marginBottom="@dimen/space_s">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/aruskas_logo_v2"
                    android:contentDescription="ArusKas Logo" />

                <TextView
                    style="@style/TextAppearance.ArusKas.Display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="ArusKas"
                    android:textSize="26sp"
                    android:textColor="@color/colorTextPrimary"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btn_logout"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_logout"
                    android:contentDescription="Keluar"
                    app:tint="@color/colorTextSecondary"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp" />

            </LinearLayout>

            <!-- Main Gradient Balance Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_l"
                android:layout_marginVertical="@dimen/space_s"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_gradient_header"
                    android:orientation="vertical"
                    android:padding="@dimen/space_xl">

                    <!-- Balance Row -->
                    <TextView
                        style="@style/TextAppearance.ArusKas.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SALDO SAAT INI"
                        android:textColor="#D1D5DB"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_total_balance"
                        style="@style/TextAppearance.ArusKas.Display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Rp 0"
                        android:textColor="@color/white"
                        android:textSize="32sp" />

                    <!-- Trend Indicator -->
                    <LinearLayout
                        android:id="@+id/layout_trend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="#1AFFFFFF"
                        android:paddingHorizontal="@dimen/space_s"
                        android:paddingVertical="4dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/img_trend_arrow"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_trend_up"
                            app:tint="@color/colorIncome" />

                        <TextView
                            android:id="@+id/text_trend_percentage"
                            style="@style/TextAppearance.ArusKas.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="0% vs bulan lalu"
                            android:textColor="@color/white" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/space_l"
                        android:background="#26FFFFFF" />

                    <!-- Income / Expense Split -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Income Block -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.ArusKas.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PEMASUKAN"
                                android:textColor="#D1D5DB" />

                            <TextView
                                android:id="@+id/text_month_income"
                                style="@style/TextAppearance.ArusKas.Number"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Rp 0"
                                android:textColor="@color/colorIncome"
                                android:textSize="16sp" />

                        </LinearLayout>

                        <!-- Divider Line -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"
                            android:background="#26FFFFFF" />

                        <!-- Expense Block -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/space_l"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.ArusKas.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PENGELUARAN"
                                android:textColor="#D1D5DB" />

                            <TextView
                                android:id="@+id/text_month_expense"
                                style="@style/TextAppearance.ArusKas.Number"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Rp 0"
                                android:textColor="@color/colorExpense"
                                android:textSize="16sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Navigation Shortcuts (2x2 Grid) -->
            <TextView
                style="@style/TextAppearance.ArusKas.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_l"
                android:layout_marginTop="@dimen/space_l"
                android:text="MENU CEPAT"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginVertical="@dimen/space_s"
                android:columnCount="2"
                android:rowCount="2">

                <!-- 1. Category -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_shortcut_category"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/colorBorder"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_m">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_badge_circle"
                            android:backgroundTint="@color/colorShortcutCategoryBg">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dashboard_category"
                                app:tint="@color/colorShortcutCategory" />
                        </FrameLayout>

                        <TextView
                            style="@style/TextAppearance.ArusKas.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Kategori"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Budget -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_shortcut_budget"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/colorBorder"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_m">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_badge_circle"
                            android:backgroundTint="@color/colorShortcutBudgetBg">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dashboard_budget"
                                app:tint="@color/colorShortcutBudget" />
                        </FrameLayout>

                        <TextView
                            style="@style/TextAppearance.ArusKas.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Anggaran"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Report -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_shortcut_report"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/colorBorder"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_m">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_badge_circle"
                            android:backgroundTint="@color/colorShortcutReportBg">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dashboard_report"
                                app:tint="@color/colorShortcutReport" />
                        </FrameLayout>

                        <TextView
                            style="@style/TextAppearance.ArusKas.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Laporan"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Recurring -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_shortcut_recurring"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/colorBorder"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_m">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_badge_circle"
                            android:backgroundTint="@color/colorShortcutRecurringBg">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dashboard_recurring"
                                app:tint="@color/colorShortcutRecurring" />
                        </FrameLayout>

                        <TextView
                            style="@style/TextAppearance.ArusKas.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Tagihan"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Mini Trend Chart Section -->
            <TextView
                style="@style/TextAppearance.ArusKas.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_l"
                android:layout_marginTop="@dimen/space_l"
                android:text="TREN 6 BULAN TERAKHIR"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginHorizontal="@dimen/space_l"
                android:layout_marginVertical="@dimen/space_s"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/colorBorder"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/colorSurface">

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/bar_chart_trend"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/space_m" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Transactions Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_l"
                android:layout_marginTop="@dimen/space_l"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/TextAppearance.ArusKas.Caption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TRANSAKSI TERBARU"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_see_all_transactions"
                    style="@style/TextAppearance.ArusKas.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat Semua"
                    android:textColor="@color/colorPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s">

                <!-- Recent Transactions RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_recent_transactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_recent_transaction" />

                <!-- Empty State Message -->
                <TextView
                    android:id="@+id/text_empty_transactions"
                    style="@style/TextAppearance.ArusKas.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/space_xl"
                    android:text="Belum ada transaksi bulan ini.\nKetuk tombol + di bawah untuk mencatat."
                    android:textAlignment="center"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB for adding new transaction -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_transaction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/space_xl"
        android:backgroundTint="@color/colorPrimary"
        android:contentDescription="Add new transaction"
        app:srcCompat="@drawable/ic_plus"
        app:tint="@color/white"
        app:elevation="@dimen/fab_elevation" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
