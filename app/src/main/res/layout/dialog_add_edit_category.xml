<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_xl"
        android:paddingBottom="@dimen/space_xl">

        <!-- Bottom Sheet Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_s"
            android:layout_marginBottom="@dimen/space_xl"
            android:background="@color/colorBorder" />

        <!-- Title -->
        <TextView
            android:id="@+id/text_dialog_title"
            style="@style/TextAppearance.ArusKas.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            android:text="Tambah Kategori" />

        <!-- Name Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_name_layout"
            style="@style/Widget.ArusKas.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            android:hint="Nama Kategori"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_category_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:maxLength="50"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Category Type Selector -->
        <TextView
            style="@style/TextAppearance.ArusKas.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_s"
            android:text="Tipe Kategori"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_category_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_expense"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pengeluaran"
                app:strokeColor="@color/colorExpense"
                android:textColor="@color/colorExpense"
                app:cornerRadius="@dimen/button_corner_radius" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_income"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pemasukan"
                app:strokeColor="@color/colorIncome"
                android:textColor="@color/colorIncome"
                app:cornerRadius="@dimen/button_corner_radius" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Icon Picker Grid -->
        <TextView
            style="@style/TextAppearance.ArusKas.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_s"
            android:text="Pilih Ikon Kategori"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layout_icon_picker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_s" />
        </HorizontalScrollView>

        <!-- Color Picker Grid -->
        <TextView
            style="@style/TextAppearance.ArusKas.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_s"
            android:text="Pilih Warna Kategori"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layout_color_picker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_s" />
        </HorizontalScrollView>

        <!-- Bottom Actions (Delete & Save) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="@dimen/space_l">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_category"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_m"
                android:textColor="@color/colorExpense"
                app:strokeColor="@color/colorExpense"
                app:strokeWidth="1dp"
                android:text="Hapus"
                app:cornerRadius="@dimen/button_corner_radius"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_category"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@color/white"
                android:text="Simpan"
                app:cornerRadius="@dimen/button_corner_radius" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
