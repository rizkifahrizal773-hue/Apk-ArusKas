<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".activity.ReportActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Custom Toolbar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/colorSurface"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/space_s"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:contentDescription="Go Back" />

            <TextView
                style="@style/TextAppearance.ArusKas.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_s"
                android:text="Laporan &amp; Analisis"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btn_back"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Month Filter -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_month_filter"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_m"
                android:text="Juli 2026"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- TabLayout to switch between Pie Chart & Bar Chart -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            app:tabIndicatorColor="@color/colorPrimary"
            app:tabSelectedTextColor="@color/colorPrimary"
            app:tabTextColor="@color/colorTextSecondary">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distribusi Kategori" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tren Keuangan" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Content Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- 1. Pie Chart Section (Category Breakdown) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/layout_pie_chart_section"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="40dp">

                    <!-- Type Filter Toggle -->
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggle_report_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/space_l"
                        android:layout_marginVertical="@dimen/space_m"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_report_expense"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pengeluaran"
                            app:cornerRadius="@dimen/button_corner_radius" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_report_income"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pemasukan"
                            app:cornerRadius="@dimen/button_corner_radius" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Pie Chart widget -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:layout_marginHorizontal="@dimen/space_l"
                        android:layout_marginBottom="@dimen/space_m"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:strokeColor="@color/colorBorder"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="@color/colorSurface">

                        <com.github.mikephil.charting.charts.PieChart
                            android:id="@+id/pie_chart_distribution"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="@dimen/space_m" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Distribution Breakdown List -->
                    <TextView
                        style="@style/TextAppearance.ArusKas.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/space_l"
                        android:layout_marginTop="@dimen/space_m"
                        android:text="URUTAN KATEGORI TERBESAR"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_report_categories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_report_category" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- 2. Bar Chart Section (Monthly Trend) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/layout_bar_chart_section"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="40dp">

                    <TextView
                        style="@style/TextAppearance.ArusKas.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/space_l"
                        android:layout_marginVertical="@dimen/space_m"
                        android:text="GRAFIK TREN BULANAN (6 BULAN)"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="340dp"
                        android:layout_marginHorizontal="@dimen/space_l"
                        android:layout_marginBottom="@dimen/space_m"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:strokeColor="@color/colorBorder"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="@color/colorSurface">

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/bar_chart_trend"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="@dimen/space_m" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Summary Analysis Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/space_l"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:strokeColor="@color/colorBorder"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="@color/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_xl">

                            <TextView
                                style="@style/TextAppearance.ArusKas.Title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Analisis Singkat"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/text_trend_analysis"
                                style="@style/TextAppearance.ArusKas.Body"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Memuat analisis tren keuangan Anda..." />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- Empty State -->
            <TextView
                android:id="@+id/text_empty_report"
                style="@style/TextAppearance.ArusKas.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="@dimen/space_xl"
                android:text="Belum ada data keuangan untuk periode ini."
                android:textAlignment="center"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <!-- Transparent Loading Screen Overlay -->
    <FrameLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorLoadingBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            app:indicatorColor="@color/colorPrimary" />

    </FrameLayout>

</FrameLayout>
