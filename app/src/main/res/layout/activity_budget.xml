<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".activity.BudgetActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Custom Toolbar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/colorSurface"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/space_s"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:contentDescription="Go Back" />

            <TextView
                style="@style/TextAppearance.ArusKas.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_s"
                android:text="Anggaran Belanja"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btn_back"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Month Filter -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_month_filter"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_m"
                android:text="Juli 2026"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp">

                <!-- Cumulative Summary Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_l"
                    android:layout_marginVertical="@dimen/space_m"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/colorBorder"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_xl">

                        <TextView
                            style="@style/TextAppearance.ArusKas.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL ANGGARAN BULAN INI"
                            android:textStyle="bold" />

                        <!-- Spent vs Limit display -->
                        <TextView
                            android:id="@+id/text_total_limit_summary"
                            style="@style/TextAppearance.ArusKas.Number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Rp 0 terpakai dari Rp 0"
                            android:textSize="18sp"
                            android:textColor="@color/colorTextPrimary" />

                        <!-- Limit Progress bar -->
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progress_total_budget"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="12dp"
                            app:trackColor="@color/colorBorder"
                            app:trackCornerRadius="5dp"
                            app:indicatorColor="@color/colorPrimary"
                            tools:progress="50" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Section Header -->
                <TextView
                    style="@style/TextAppearance.ArusKas.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_l"
                    android:layout_marginTop="@dimen/space_m"
                    android:text="ANGGARAN PER KATEGORI"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_s">

                    <!-- Budget Recycler -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_budgets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_budget" />

                    <!-- Empty State -->
                    <TextView
                        android:id="@+id/text_empty_budgets"
                        style="@style/TextAppearance.ArusKas.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/space_xl"
                        android:text="Belum ada anggaran belanja untuk bulan ini.\nKetuk tombol + di bawah untuk mengatur."
                        android:textAlignment="center"
                        android:visibility="gone" />

                </FrameLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- FAB for adding new budget -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_budget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/space_xl"
        android:backgroundTint="@color/colorPrimary"
        android:contentDescription="Add new budget"
        app:srcCompat="@drawable/ic_plus"
        app:tint="@color/white"
        app:elevation="@dimen/fab_elevation" />

    <!-- Transparent Loading Screen Overlay -->
    <FrameLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorLoadingBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            app:indicatorColor="@color/colorPrimary" />

    </FrameLayout>

</FrameLayout>
