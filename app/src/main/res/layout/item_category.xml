<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_category"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_l"
    android:layout_marginVertical="@dimen/space_s"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeColor="@color/colorBorder"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/colorSurface"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_l">

        <!-- Circular Badge with white category icon -->
        <FrameLayout
            android:id="@+id/view_badge_bg"
            android:layout_width="@dimen/badge_size"
            android:layout_height="@dimen/badge_size"
            android:background="@drawable/bg_badge_circle"
            android:backgroundTint="@color/colorPrimary">

            <ImageView
                android:id="@+id/img_category_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_category_other"
                android:contentDescription="Category Icon" />

        </FrameLayout>

        <!-- Category Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_l"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_category_name"
                style="@style/TextAppearance.ArusKas.Title"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Makanan" />

            <TextView
                android:id="@+id/text_category_type"
                style="@style/TextAppearance.ArusKas.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Pengeluaran"
                android:textColor="@color/colorExpense" />

        </LinearLayout>

        <!-- Edit Button/Icon -->
        <ImageView
            android:id="@+id/img_edit_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_edit"
            android:contentDescription="Edit Category"
            app:tint="@color/colorTextSecondary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
