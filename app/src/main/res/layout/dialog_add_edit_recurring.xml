<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <!-- Handle line indicator for BottomSheet -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/space_l"
            android:background="@color/colorBorder"
            android:backgroundTint="@color/colorBorder" />

        <TextView
            android:id="@+id/text_dialog_title"
            style="@style/TextAppearance.ArusKas.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            android:text="Atur Pengingat Tagihan"
            android:textSize="18sp" />

        <!-- 1. Bill Title Description -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_title_layout"
            style="@style/Widget.ArusKas.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_m"
            android:hint="Nama / Deskripsi Tagihan"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLength="100"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 2. Type Selector Toggle -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_recurring_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_m"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_expense"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pengeluaran"
                app:strokeColor="@color/colorExpense"
                android:textColor="@color/colorExpense"
                app:cornerRadius="@dimen/button_corner_radius" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_income"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pemasukan"
                app:strokeColor="@color/colorIncome"
                android:textColor="@color/colorIncome"
                app:cornerRadius="@dimen/button_corner_radius" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- 3. Amount Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_amount_layout"
            style="@style/Widget.ArusKas.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_m"
            android:hint="Nominal Tagihan"
            app:prefixText="Rp "
            app:prefixTextColor="@color/colorTextPrimary"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1"
                style="@style/TextAppearance.ArusKas.Number"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 4. Category Selector Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_category_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_m"
            android:hint="Pilih Kategori"
            app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
            app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
            app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
            app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
            app:boxStrokeColor="@color/colorPrimary"
            app:hintTextColor="@color/colorPrimary"
            app:errorEnabled="true">

            <AutoCompleteTextView
                android:id="@+id/input_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 5. Due Day Picker (1-31) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_due_day_layout"
            style="@style/Widget.ArusKas.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            android:hint="Tanggal Jatuh Tempo Bulanan (1 - 31)"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_due_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 6. Alarm Switch reminder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_xl">

            <TextView
                style="@style/TextAppearance.ArusKas.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Aktifkan Notifikasi Pengingat"
                android:textColor="@color/colorTextPrimary" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_dialog_reminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

        </LinearLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_recurring"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:text="Simpan Tagihan"
            app:cornerRadius="@dimen/button_corner_radius" />

        <!-- Delete Button (Edit mode) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_recurring"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="@dimen/space_m"
            android:textColor="@color/colorExpense"
            app:strokeColor="@color/colorExpense"
            app:strokeWidth="1dp"
            android:text="Hapus Tagihan"
            app:cornerRadius="@dimen/button_corner_radius"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
