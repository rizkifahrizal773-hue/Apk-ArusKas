<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_error"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/space_xl"
    android:visibility="gone">

    <ImageView
        android:id="@+id/img_error_illustration"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="@dimen/space_l"
        android:src="@drawable/ic_error_state_illustration"
        android:contentDescription="Network error occurred" />

    <TextView
        android:id="@+id/text_error_title"
        style="@style/TextAppearance.ArusKas.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_s"
        android:textColor="@color/colorExpense"
        android:text="Gagal Memuat Data"
        android:textAlignment="center" />

    <TextView
        android:id="@+id/text_error_message"
        style="@style/TextAppearance.ArusKas.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_xl"
        android:text="Terjadi kesalahan jaringan. Periksa koneksi internet Anda dan coba lagi."
        android:textAlignment="center" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_error_retry"
        style="@style/Widget.Material3.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/colorPrimary"
        android:textColor="@color/white"
        android:text="Coba Lagi"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="@dimen/button_corner_radius"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</LinearLayout>
