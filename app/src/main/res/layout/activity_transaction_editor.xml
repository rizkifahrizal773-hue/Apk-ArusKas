<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".activity.TransactionEditorActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Custom Toolbar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/colorSurface"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/space_s"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:contentDescription="Go Back" />

            <TextView
                android:id="@+id/text_title"
                style="@style/TextAppearance.ArusKas.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_s"
                android:text="Transaksi Baru"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btn_back"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Form ScrollView -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_l">

                <!-- Form Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/colorBorder"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_xl">

                        <!-- 1. Transaction Type Toggle -->
                        <TextView
                            style="@style/TextAppearance.ArusKas.Caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_s"
                            android:text="Tipe Transaksi"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggle_transaction_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_xl"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_type_expense"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pengeluaran"
                                app:strokeColor="@color/colorExpense"
                                android:textColor="@color/colorExpense"
                                app:cornerRadius="@dimen/button_corner_radius" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_type_income"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pemasukan"
                                app:strokeColor="@color/colorIncome"
                                android:textColor="@color/colorIncome"
                                app:cornerRadius="@dimen/button_corner_radius" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <!-- 2. Amount Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_amount_layout"
                            style="@style/Widget.ArusKas.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_m"
                            android:hint="Nominal Uang"
                            app:prefixText="Rp "
                            app:prefixTextColor="@color/colorTextPrimary"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_amount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLines="1"
                                style="@style/TextAppearance.ArusKas.Number"
                                android:textSize="18sp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- 3. Category Dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_category_layout"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:hint="Pilih Kategori"
                            app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
                            app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                            app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
                            app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
                            app:boxStrokeColor="@color/colorPrimary"
                            app:hintTextColor="@color/colorPrimary"
                            app:errorEnabled="true">

                            <AutoCompleteTextView
                                android:id="@+id/input_category"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/btn_new_category_shortcut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginBottom="@dimen/space_xl"
                            android:text="+ Tambah Kategori Baru"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground" />

                        <!-- 4. Date Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_date_layout"
                            style="@style/Widget.ArusKas.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_xl"
                            android:hint="Tanggal Transaksi"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_date"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:focusable="false"
                                android:clickable="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- 5. Note Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_note_layout"
                            style="@style/Widget.ArusKas.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_xl"
                            android:hint="Catatan (Opsional)"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_note"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine"
                                android:maxLength="255"
                                android:maxLines="4" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- 6. Receipt Photo Attach -->
                        <TextView
                            style="@style/TextAppearance.ArusKas.Caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_s"
                            android:text="Bukti Pembayaran (Opsional)"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="@dimen/space_m">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_pick_camera"
                                style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="@dimen/space_s"
                                android:text="Ambil Foto"
                                app:icon="@drawable/ic_camera"
                                app:cornerRadius="@dimen/button_corner_radius"
                                app:strokeColor="@color/colorPrimary"
                                android:textColor="@color/colorPrimary" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_pick_gallery"
                                style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pilih Galeri"
                                app:icon="@drawable/ic_gallery"
                                app:cornerRadius="@dimen/button_corner_radius"
                                app:strokeColor="@color/colorPrimary"
                                android:textColor="@color/colorPrimary" />

                        </LinearLayout>

                        <!-- Image Preview Thumbnail Layout -->
                        <FrameLayout
                            android:id="@+id/layout_receipt_preview"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:visibility="gone">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/img_receipt_preview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                app:shapeAppearanceOverlay="@style/RoundedShapeAppearanceBottomSheet" />

                            <!-- Delete Photo Overlay Button -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_gravity="bottom"
                                android:background="#99000000" />

                            <TextView
                                android:id="@+id/btn_remove_receipt"
                                style="@style/TextAppearance.ArusKas.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|center_horizontal"
                                android:layout_marginBottom="12dp"
                                android:text="Hapus Lampiran Bukti"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />
                        </FrameLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Actions (Delete / Save) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/space_xl"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_transaction"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:backgroundTint="@color/colorPrimary"
                        android:textColor="@color/white"
                        android:text="Simpan Transaksi"
                        app:cornerRadius="@dimen/button_corner_radius" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_delete_transaction"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="@dimen/space_m"
                        android:textColor="@color/colorExpense"
                        app:strokeColor="@color/colorExpense"
                        app:strokeWidth="1dp"
                        android:text="Hapus Transaksi Ini"
                        app:cornerRadius="@dimen/button_corner_radius"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Transparent Loading Screen Overlay -->
    <FrameLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorLoadingBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            app:indicatorColor="@color/colorPrimary" />

    </FrameLayout>

</FrameLayout>
